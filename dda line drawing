#include<stdio.h>
#include<graphics.h>
#include<math.h>
#include<conio.h>
#include<dos.h>

void main()
{
int gd=DETECT,gm;
float x1,y1,x2,y2,x,y,dx,dy,step;
int i;

initgraph(&gd,&gm,"C:\\TURBOC3\\BGI");

printf("Enter x1 y1: ");
scanf("%f%f",&x1,&y1);

printf("Enter x2 y2: ");
scanf("%f%f",&x2,&y2);

dx=x2-x1;
dy=y2-y1;

if(abs(dx)>abs(dy))
step=abs(dx);
else
step=abs(dy);

dx=dx/step;
dy=dy/step;

x=x1;
y=y1;

for(i=0;i<=step;i++)
{
putpixel(x,y,WHITE);
x=x+dx;
y=y+dy;
delay(10);
}

getch();
closegraph();
}
